# Python cache / bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local runtime caches
.cache/*

# OS / editor noise
.DS_Store
.idea/
